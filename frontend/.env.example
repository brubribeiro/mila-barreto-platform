# Desenvolvimento local (padrão)
VITE_API_URL=/api
# O Vite faz proxy de /api para http://localhost:3333 (vite.config.ts)

# Só use URL absoluta se não estiver rodando o frontend via Vite:
# VITE_API_URL=http://localhost:3333/api

VITE_GOOGLE_CLIENT_ID=

# Sobrescreva em frontend/.env.local (gitignored). Veja .env.local.example
